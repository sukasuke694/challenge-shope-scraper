# Server Configuration
PORT=3000

# Proxy Configuration
USE_PROXY=true

# PROXIES should be a JSON array of proxy configurations
# Format: [{"host":"proxy-host","port":port,"auth":{"username":"user","password":"pass"}}]
# 
# Free Proxy Sources (for testing):
# - https://www.proxy-list.download/
# - https://free-proxy-list.net/
# - https://hideip.me/
# 
# Paid Proxy Services (recommended for production):
# - Bright Data (Luminati)
# - Oxylabs
# - Smartproxy
# - ScraperAPI
#
# Example with authentication:
# PROXIES=[{"host":"proxy1.example.com","port":8080,"auth":{"username":"user","password":"pass"}},{"host":"proxy2.example.com","port":8080}]
#
# Example without authentication:
# PROXIES=[{"host":"123.45.67.89","port":8080},{"host":"98.76.54.32","port":3128}]

PROXIES=[{"host":"127.0.0.1","port":8080}]

# Shopee Cookies Configuration (Optional but recommended for bypassing anti-fraud)
# To get Shopee cookies:
# 1. Open Shopee in browser (https://shopee.tw or https://shopee.co.id)
# 2. Login to your Shopee account
# 3. Open Developer Tools (F12)
# 4. Go to Application tab → Cookies
# 5. Select Shopee domain
# 6. Copy important cookies: SPC_EC, SPC_CLIENT_ID, SPC_F, SPC_T_ID, SPC_T
# 7. Paste them here in format: cookie1=value1; cookie2=value2; cookie3=value3
#
# Example:
# SHOPEE_COOKIES=SPC_EC=abc123; SPC_CLIENT_ID=xyz789; SPC_F=def456; SPC_T_ID=ghi012; SPC_T=jkl345

SHOPEE_COOKIES=
